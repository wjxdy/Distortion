theme_override_colors/font_color = Color(0.92, 0.94, 1, 1)
theme_override_constants/line_spacing = 12
theme_override_font_sizes/font_size = 30
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 3
text = "走失、纠纷、报案、笔录。

有人丢了东西。
有人丢了人。
也有人只是丢了
自己还正常的证据。"

[node name="Slide5" type="Control" parent="Slides"]
visible = false
clip_contents = true
