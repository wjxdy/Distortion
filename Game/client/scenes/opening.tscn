[node name="Text" type="Label" parent="Slides/Slide3"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 220.0
offset_right = -220.0
theme_override_colors/font_color = Color(0.92, 0.94, 1, 1)
theme_override_constants/line_spacing = 12
theme_override_font_sizes/font_size = 30
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 3
text = "我是一名警探。

听起来像是追查真相的人。

实际大多数时候，
我只是在给那些破事
找一个能盖章的说法。"

[node name="Slide4" type="Control" parent="Slides"]
