[node name="Text" type="Label" parent="Slides/Slide1"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 220.0
offset_right = -220.0
theme_override_colors/font_color = Color(0.92, 0.94, 1, 1)
theme_override_constants/line_spacing = 12
theme_override_font_sizes/font_size = 30
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 3
text = "生日、病历、遗言、聊天记录。

连一句“我爱你”
都能被备份、归档、标注时间。

好像只要存得够久，
人就真的不会失去什么。"

[node name="Slide2" type="Control" parent="Slides"]
visible = false
clip_contents = true
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Bg" type="ColorRect" parent="Slides/Slide2"]
layout_mode = 1
