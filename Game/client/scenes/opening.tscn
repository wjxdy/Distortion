[node name="Shade" type="ColorRect" parent="Slides/Slide2"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0, 0, 0, 0.42)

[node name="Text" type="Label" parent="Slides/Slide2"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 220.0
offset_right = -220.0
theme_override_colors/font_color = Color(0.92, 0.94, 1, 1)
theme_override_constants/line_spacing = 12
theme_override_font_sizes/font_size = 30
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 3
text = "警局也一样。

报案人说自己记得。
档案说不是那样。
终端弹出一行结论。

于是所有人都松了口气：

“系统有记录。”"

[node name="Slide3" type="Control" parent="Slides"]
visible = false
clip_contents = true
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Bg" type="ColorRect" parent="Slides/Slide3"]
layout_mode = 1
