horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 3
text = "这年头，
人连自己有没有忘事，
都要先问一遍系统。

挺方便的。

也挺可笑的。"

[node name="Slide1" type="Control" parent="Slides"]
visible = false
clip_contents = true
