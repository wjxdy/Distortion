# 复制本文件为 .env，并填入真实值。
# .env 已被 .gitignore 忽略，绝不会提交进仓库。
KIMI_API_KEY=在此填入你的月之暗面 API Key
KIMI_BASE_URL=https://api.moonshot.cn/v1
# 默认用非推理的 moonshot-v1-32k（快，~1s）。kimi-k2.x 是推理模型，回复慢(4~20s)，不建议用于实时对话。
KIMI_MODEL=moonshot-v1-32k
# 可选：温度。v1 系可自由设(0.6 兼顾稳定与个性)；kimi-k2.x 推理模型只接受 1。
KIMI_TEMPERATURE=0.6
PORT=8787
